# =============================================================================
# BaseBuilder — AI Agent Toolkit on Base
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Coinbase Developer Platform (CDP)
# Get your keys at: https://portal.cdp.coinbase.com
# -----------------------------------------------------------------------------
CDP_API_KEY_ID=your_cdp_api_key_id
CDP_API_KEY_SECRET=your_cdp_api_key_secret
CDP_WALLET_SECRET=your_cdp_wallet_secret

# -----------------------------------------------------------------------------
# OpenAI
# Get your key at: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key

# (Optional) Override the default model. gpt-4o-mini is cost-efficient.
# OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Network Configuration
# Options: base-sepolia (testnet) | base-mainnet
# Start with base-sepolia for free testing!
# -----------------------------------------------------------------------------
NETWORK_ID=base-sepolia

# -----------------------------------------------------------------------------
# Supabase — Agent Memory & Persistence (Feature #1)
# Get your keys at: https://supabase.com/dashboard/project/_/settings/api
# Run supabase/schema.sql in your Supabase SQL Editor first.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Use the service role key for full DB access from the server (recommended)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
